{
  "_workshop_note": [
    "Metamodel schema for the GAIA workshop pipeline. Pure schema — no per-question answers.",
    "",
    "Contains:",
    "  - vocabulary        : known item_types and relation_sids in the graph",
    "  - relation_labels   : human-readable aliases for relation sids",
    "  - relation_schema   : per-sid allowed (from_types, to_types) — the structural schema",
    "                        SystemWeaver itself enforces. Used to flag data-drift edges.",
    "  - relation_whitelists: named relation sets per question intent. Mirrors the",
    "                        SidsToFollow configuration used by SystemWeaver's Trace View,",
    "                        Design Trace View, and Coverage view. The planner picks one",
    "                        (or a union) based on the question.",
    "  - requirement_types : item_types where the enriched data has is_requirement_type=true.",
    "  - requirement_levels: distinct requirement_level values in the enriched data.",
    "  - type_aliases      : natural-language phrase -> item_type(s). Consumed by the",
    "                        rule-based planner.",
    "  - intent_keywords   : phrases hinting at upstream/downstream traversal intent.",
    "  - defaults          : generic guard rails for packet size.",
    "",
    "WORKSHOP SHORTCUT",
    "-----------------",
    "type_aliases is the only question-aware ingredient and is consumed by a deterministic",
    "rule-based planner in plan_question(). In production, replace the planner with:",
    "  (a) a small LLM planner that sees ONLY this metamodel + the question text,",
    "      never node contents, and returns a QuestionPolicy,",
    "  (b) an NER + entity-linking pipeline tuned to the organization's naming conventions."
  ],

  "vocabulary": {
    "item_types": [
      "Baseline Architecture",
      "Stakeholder Requirements Area",
      "Stakeholder Requirements Group",
      "Stakeholder Req",
      "Stakeholder Requirements",
      "Incoming Stakeholder Requirements",
      "Function Requirement",
      "Function Requirement Group",
      "Function Specification",
      "Function Inbox",
      "Function",
      "Design Requirement",
      "Design Requirement Group",
      "Legal Requirement",
      "Legal requirements",
      "Req Trace Item",
      "Test Case",
      "Test Specification",
      "Test Scope for Function Requirements",
      "Test Scope",
      "Functional safety requirement",
      "Safety Goal",
      "Cybersecurity Claim",
      "Cybersecurity Goal",
      "Cybersecurity Requirement"
    ],
    "relation_sids": [
      "SP0003", "SP0006", "SP0129", "SP0231",
      "SP0645", "SP0648", "SP0670", "SP0672", "SP0688", "SP0691",
      "ITRQ", "ITTR", "ITEC", "ITSI", "ITTX"
    ]
  },

  "relation_labels": {
    "SP0003": "Traced from",
    "SP0006": "Derives",
    "SP0129": "Design Requirement Group -> Design Requirement",
    "SP0231": "Stakeholder Requirements Group -> Stakeholder Req",
    "SP0645": "Function -> Function Inbox",
    "SP0648": "Function Requirement Group -> Function Requirement",
    "SP0670": "Function Inbox -> Stakeholder Req",
    "SP0672": "Function Inbox -> Legal Requirement",
    "SP0688": "Function -> Function Specification",
    "SP0691": "Function Specification -> Function Requirement Group",
    "ITRQ":   "Test Case -> requirement",
    "ITTR":   "Test Specification -> requirement",
    "ITEC":   "Test Specification -> Test Case",
    "ITSI":   "Test Specification -> requirement group",
    "ITTX":   "Test Scope -> Test Specification"
  },

  "relation_schema": {
    "_note": "Allowed (from_types, to_types) per relation_sid. Derived from the enriched graph contents. Extractor emits an edge_schema_violation warning if an edge in the packet doesn't fit this schema.",
    "SP0003": {"from": ["Req Trace Item"], "to": ["Stakeholder Req", "Function Requirement", "Legal Requirement", "Design Requirement"]},
    "SP0006": {"from": ["Req Trace Item"], "to": ["Stakeholder Req", "Function Requirement", "Legal Requirement", "Design Requirement"]},
    "SP0129": {"from": ["Design Requirement Group"], "to": ["Design Requirement"]},
    "SP0231": {"from": ["Stakeholder Requirements Group"], "to": ["Stakeholder Req"]},
    "SP0645": {"from": ["Function"], "to": ["Function Inbox"]},
    "SP0648": {"from": ["Function Requirement Group"], "to": ["Function Requirement"]},
    "SP0670": {"from": ["Function Inbox"], "to": ["Stakeholder Req"]},
    "SP0672": {"from": ["Function Inbox"], "to": ["Legal Requirement"]},
    "SP0688": {"from": ["Function"], "to": ["Function Specification"]},
    "SP0691": {"from": ["Function Specification"], "to": ["Function Requirement Group"]},
    "ITRQ":   {"from": ["Test Case"], "to": ["Function Requirement", "Design Requirement", "Stakeholder Req"]},
    "ITTR":   {"from": ["Test Specification"], "to": ["Function Requirement", "Design Requirement", "Stakeholder Req"]},
    "ITEC":   {"from": ["Test Specification"], "to": ["Test Case"]},
    "ITSI":   {"from": ["Test Specification"], "to": ["Function Requirement Group", "Design Requirement Group", "Stakeholder Requirements Group"]},
    "ITTX":   {"from": ["Test Scope"], "to": ["Test Specification"]}
  },

  "relation_whitelists": {
    "_note": "Named relation-sid sets per question intent. The planner picks one (or a union) based on what the question is asking. Modelled on SystemWeaver's SidsToFollow configuration used by Trace View, Design Trace View, and Coverage view.",
    "requirement_trace":     ["SP0003", "SP0006"],
    "test_trace":            ["ITRQ", "ITTR", "ITEC", "ITSI"],
    "structural_containment": ["SP0129", "SP0231", "SP0645", "SP0648", "SP0670", "SP0672", "SP0688", "SP0691"],
    "all_trace":             ["SP0003", "SP0006", "SP0129", "SP0231", "SP0645", "SP0648", "SP0670", "SP0672", "SP0688", "SP0691", "ITRQ", "ITTR", "ITEC", "ITSI", "ITTX"]
  },

  "requirement_types": [
    "Stakeholder Req",
    "Legal Requirement",
    "Function Requirement",
    "Design Requirement",
    "Functional safety requirement",
    "Safety Goal",
    "Cybersecurity Claim",
    "Cybersecurity Goal",
    "Cybersecurity Requirement"
  ],

  "requirement_levels": {
    "_note": "Valid values of the requirement_level field on nodes where is_requirement_type=true.",
    "values": ["stakeholder", "legal", "function", "design", "cybersecurity", "standard_process", "generic_requirement"],
    "phrase_to_level": {
      "stakeholder requirement": "stakeholder",
      "stakeholder requirements": "stakeholder",
      "legal requirement": "legal",
      "legal requirements": "legal",
      "function requirement": "function",
      "function requirements": "function",
      "design requirement": "design",
      "design requirements": "design",
      "cybersecurity requirement": "cybersecurity",
      "cybersecurity requirements": "cybersecurity"
    }
  },

  "type_aliases": [
    { "aliases": ["legal requirement", "legal requirements", "legal regulation"], "item_types": ["Legal Requirement"] },
    { "aliases": ["stakeholder requirement", "stakeholder requirements", "stakeholder req"], "item_types": ["Stakeholder Req"] },
    { "aliases": ["function requirement", "function requirements"], "item_types": ["Function Requirement"] },
    { "aliases": ["design requirement", "design requirements"], "item_types": ["Design Requirement"] },
    { "aliases": ["test case", "test cases"], "item_types": ["Test Case"] },
    { "aliases": ["test specification", "test specifications", "test spec", "test specs"], "item_types": ["Test Specification"] },
    { "aliases": ["test artifact", "test artifacts"], "item_types": ["Test Case", "Test Specification"] },
    { "aliases": ["trace item", "req trace item"], "item_types": ["Req Trace Item"] }
  ],

  "intent_keywords": {
    "downstream": ["downstream", "further downstream", "impacted", "affected if", "gets removed", "is tightened", "is changed", "is modified"],
    "upstream":   ["upstream", "traced from", "originates from", "parent requirement", "comes from"]
  },

  "defaults": {
    "max_nodes": 150,
    "max_edges": 300
  }
}
